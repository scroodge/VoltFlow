OPENAI_API_KEY=your-openai-api-key
LLM_BASE_URL=your base url
LLM_MODEL=qwen2.5:14b
LLM_API_KEY=your api key
LLM_MAX_TOKENS=512
# Server-only HMAC secret for hashed VoltFlow Mate API-key lookup. Generate a
# long random value; configure the same value for the Next app and Edge Function.
BYDMATE_API_KEY_PEPPER=replace-with-a-long-random-secret
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:your@email.com
# Donation page bank card numbers (src/lib/support.ts) — not secret, just kept
# out of source so rotating a card doesn't need a code deploy.
NEXT_PUBLIC_SUPPORT_CARD_BY=your-belarus-card-number
NEXT_PUBLIC_SUPPORT_CARD_RU=your-russia-card-number
